{
  "name": "npgkanbanstyletaskboard.client",
  "version": "0.0.0",
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prestart": "node aspnetcore-https",
    "start:windows": "vite --host 127.0.0.1 --https --cert \"%APPDATA%\\ASP.NET\\https\\%npm_package_name%.pem\" --key \"%APPDATA%\\ASP.NET\\https\\%npm_package_name%.key\"",
    "start:default": "vite --host 127.0.0.1 --https --cert \"$HOME/.aspnet/https/${npm_package_name}.pem\" --key \"$HOME/.aspnet/https/${npm_package_name}.key\""
  },
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.57.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}
